datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Registration {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  institution   String
  qualification String
  experience    String
  interest      String
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
}

model Feedback {
  id            String   @id @default(cuid())
  participantId String?
  day           String
  overall       Int
  pace          Int
  content       Int
  faculty       Int
  comments      String?
  createdAt     DateTime @default(now())
}
